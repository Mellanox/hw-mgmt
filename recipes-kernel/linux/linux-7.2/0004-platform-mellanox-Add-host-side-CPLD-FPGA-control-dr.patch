+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/asic3_pg_fail
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/asic4_pg_fail
+Date:		June 2026
+KernelVersion:	7.2
+Contact:	Felix Radensky <fradensky@nvidia.com>
+Description:	These files show ASIC Power Good status for each ASIC.
+		Value 1 in file means ASIC Power Good failed, 0 - otherwise.
+
+		The files are read only.
+
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_aux_pwr_or_fu
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_aux_pwr_or_reload
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_pwr_button_or_leak_con
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_comex_power
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_cpu_thermal
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_main_51v
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/reset_mgmt_pwr
+Date:		June 2026
+KernelVersion:	7.2
+Contact:	Felix Radensky <fradensky@nvidia.com>
+Description:	These files show the system reset cause, as following:
+		auxiliary power outage or field upgrade, auxiliary power outage
+		or power reload, power button press or liquid cooling connector
+		event, COMEX power related reset, CPU thermal shutdown, main
+		51V power domain failure, management power domain failure.
+		Value 1 in file means this is reset cause, 0 - otherwise.
+		Only one of the above causes could be 1 at the same time,
+		representing only last reset cause.
+
+		The files are read only.
+
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/port80
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/sgmii_phy
+Date:		June 2026
+KernelVersion:	7.2
+Contact:	Felix Radensky <fradensky@nvidia.com>
+Description:	These files expose platform diagnostic information:
+
+		port80: POST code value latched by platform hardware.
+		sgmii_phy: SGMII PHY related status.
+
+		The files are read only.
+
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/pdb1_pwr_status
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/pdb2_pwr_status
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/pdb3_pwr_status
+What:		/sys/devices/platform/mlxplat/mlxreg-io/hwmon/hwmon*/pdb4_pwr_status
+Date:		June 2026
+KernelVersion:	7.2
+Contact:	Felix Radensky <fradensky@nvidia.com>
+Description:	These files show power distribution board (PDB) DC OK status
+		for each PDB slot. Value 1 indicates power good, 0 - otherwise.
+
+		The files are read only.
diff --git a/drivers/platform/mellanox/Kconfig b/drivers/platform/mellanox/Kconfig
index e3afbe62c7f6..3e342c0a7481 100644
--- a/drivers/platform/mellanox/Kconfig
+++ b/drivers/platform/mellanox/Kconfig
@@ -105,6 +105,50 @@ config MLXBF_PMC
 	  to performance monitoring counters within various blocks in the
 	  Mellanox BlueField SoC via a sysfs interface.
 
+config NVSW_CORE
+	tristate
+	help
+	  Core infrastructure shared by Nvidia switch host platform drivers.
+	  This symbol is selected automatically by the host driver options below.
+
+config NVSW_HOST_L1
+	tristate "Nvidia L1 host CPLD/FPGA Hardware Control and Monitoring"
+	depends on X86 && DMI
+	depends on HWMON
+	select REGMAP
+	select NVSW_CORE
+	help
+	  Say Y here to include support for the FPGA/CPLD logic by host CPU
+	  equipped on Nvidia L1 switches.
+	  This driver can also be built as a module. If so the module
+	  will be called nvsw-host-l1.
+
+config NVSW_HOST_SPC5
+	tristate "Nvidia SPC5 host CPLD/FPGA Hardware Control and Monitoring"
+	depends on X86 && DMI
+	depends on HWMON
+	select REGMAP
+	select NVSW_CORE
+	help
+	  Say Y here to include support for the FPGA/CPLD logic by host CPU
+	  equipped on Nvidia SPC5 ethernet switches.
+	  This driver can also be built as a module. If so the module
+	  will be called nvsw-host-spc5.
+
+config NVSW_HOST_SPC6
+	tristate "Nvidia SPC6 host CPLD/FPGA Hardware Control and Monitoring"
+	depends on X86 && DMI
+	depends on I2C
+	depends on HWMON
+	select REGMAP
+	select REGMAP_I2C
+	select NVSW_CORE
+	help
+	  Say Y here to include support for the FPGA/CPLD logic by host CPU
+	  equipped on Nvidia SPC6 ethernet switches.
+	  This driver can also be built as a module. If so the module
+	  will be called nvsw-host-spc6.
+
 config NVSW_SN2201
 	tristate "Nvidia SN2201 platform driver support"
 	depends on HWMON && I2C
