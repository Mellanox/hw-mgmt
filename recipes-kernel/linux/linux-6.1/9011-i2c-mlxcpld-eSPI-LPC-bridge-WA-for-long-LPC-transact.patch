From c959fe5808be3560c253d2612c4ed6f75defa0a9 Mon Sep 17 00:00:00 2001
From: Michael Shych <michaelsh@nvidia.com>
Date: Tue, 21 Jul 2026 11:39:14 +0300
Subject: [PATCH v1 1/1] i2c-mlxcpld: eSPI - LPC bridge WA for long LPC
 transactions.

The eSPI-LPC bridge does not support LPC transactions longer than
one byte, so all accesses must be performed byte-by-byte.
This is a downstream temporary patch until HW solution.

Signed-off-by: Michael Shych <michaelsh@nvidia.com>
---
 drivers/i2c/busses/i2c-mlxcpld.c | 94 ++++++++------------------------
 1 file changed, 24 insertions(+), 70 deletions(-)

diff --git a/drivers/i2c/busses/i2c-mlxcpld.c b/drivers/i2c/busses/i2c-mlxcpld.c
index fd9def469132..2741cc65e1df 100644
--- a/drivers/i2c/busses/i2c-mlxcpld.c
+++ b/drivers/i2c/busses/i2c-mlxcpld.c
@@ -82,9 +82,11 @@ static void mlxcpld_i2c_lpc_write_buf_ioport(u8 *data, u8 len, u32 addr)
 {
 	int i;
 
-	for (i = 0; i < len - len % 4; i += 4)
-		outl(*(u32 *)(data + i), addr + i);
-	for (; i < len; ++i)
+	/*
+	 * The eSPI-LPC bridge does not support LPC transactions longer than
+	 * one byte, so all accesses must be performed byte-by-byte.
+	 */
+	for (i = 0; i < len; ++i)
 		outb(*(data + i), addr + i);
 }
 
@@ -92,9 +94,11 @@ static void mlxcpld_i2c_lpc_read_buf_ioport(u8 *data, u8 len, u32 addr)
 {
 	int i;
 
-	for (i = 0; i < len - len % 4; i += 4)
-		*(u32 *)(data + i) = inl(addr + i);
-	for (; i < len; ++i)
+	/*
+	 * The eSPI-LPC bridge does not support LPC transactions longer than
+	 * one byte, so all accesses must be performed byte-by-byte.
+	 */
+	for (i = 0; i < len; ++i)
 		*(data + i) = inb(addr + i);
 }
 
@@ -103,24 +107,7 @@ static void mlxcpld_i2c_read_comm_ioport(struct mlxcpld_i2c_priv *priv, u8 offs,
 {
 	u32 addr = priv->base_addr + offs;
 
-	switch (datalen) {
-	case 1:
-		*(data) = inb(addr);
-		break;
-	case 2:
-		*((u16 *)data) = inw(addr);
-		break;
-	case 3:
-		*((u16 *)data) = inw(addr);
-		*(data + 2) = inb(addr + 2);
-		break;
-	case 4:
-		*((u32 *)data) = inl(addr);
-		break;
-	default:
-		mlxcpld_i2c_lpc_read_buf_ioport(data, datalen, addr);
-		break;
-	}
+	mlxcpld_i2c_lpc_read_buf_ioport(data, datalen, addr);
 }
 
 static void mlxcpld_i2c_write_comm_ioport(struct mlxcpld_i2c_priv *priv, u8 offs,
@@ -128,33 +115,18 @@ static void mlxcpld_i2c_write_comm_ioport(struct mlxcpld_i2c_priv *priv, u8 offs
 {
 	u32 addr = priv->base_addr + offs;
 
-	switch (datalen) {
-	case 1:
-		outb(*(data), addr);
-		break;
-	case 2:
-		outw(*((u16 *)data), addr);
-		break;
-	case 3:
-		outw(*((u16 *)data), addr);
-		outb(*(data + 2), addr + 2);
-		break;
-	case 4:
-		outl(*((u32 *)data), addr);
-		break;
-	default:
-		mlxcpld_i2c_lpc_write_buf_ioport(data, datalen, addr);
-		break;
-	}
+	mlxcpld_i2c_lpc_write_buf_ioport(data, datalen, addr);
 }
 
 static void mlxcpld_i2c_lpc_write_buf_io(u8 *data, u8 len, void __iomem *addr)
 {
 	int i;
 
-	for (i = 0; i < len - len % 2; i += 2)
-		iowrite16(*(u16 *)(data + i), addr + i);
-	for (; i < len; ++i)
+	/*
+	 * The eSPI-LPC bridge does not support LPC transactions longer than
+	 * one byte, so all accesses must be performed byte-by-byte.
+	 */
+	for (i = 0; i < len; ++i)
 		iowrite8(*(data + i), addr + i);
 }
 
@@ -162,9 +134,11 @@ static void mlxcpld_i2c_lpc_read_buf_io(u8 *data, u8 len, void __iomem *addr)
 {
 	int i;
 
-	for (i = 0; i < len - len % 2; i += 2)
-		*(u16 *)(data + i) = ioread16(addr + i);
-	for (; i < len; ++i)
+	/*
+	 * The eSPI-LPC bridge does not support LPC transactions longer than
+	 * one byte, so all accesses must be performed byte-by-byte.
+	 */
+	for (i = 0; i < len; ++i)
 		*(data + i) = ioread8(addr + i);
 }
 
@@ -173,17 +147,7 @@ static void mlxcpld_i2c_read_comm_io(struct mlxcpld_i2c_priv *priv, u8 offs,
 {
 	void __iomem *addr = priv->addr + offs;
 
-	switch (datalen) {
-	case 1:
-		*(data) = ioread8(addr);
-		break;
-	case 2:
-		*((u16 *)data) = ioread16(addr);
-		break;
-	default:
-		mlxcpld_i2c_lpc_read_buf_io(data, datalen, addr);
-		break;
-	}
+	mlxcpld_i2c_lpc_read_buf_io(data, datalen, addr);
 }
 
 static void mlxcpld_i2c_write_comm_io(struct mlxcpld_i2c_priv *priv, u8 offs,
@@ -191,17 +155,7 @@ static void mlxcpld_i2c_write_comm_io(struct mlxcpld_i2c_priv *priv, u8 offs,
 {
 	void __iomem *addr = priv->addr + offs;
 
-	switch (datalen) {
-	case 1:
-		iowrite8(*(data), addr);
-		break;
-	case 2:
-		iowrite16(*((u16 *)data), addr);
-		break;
-	default:
-		mlxcpld_i2c_lpc_write_buf_io(data, datalen, addr);
-		break;
-	}
+	mlxcpld_i2c_lpc_write_buf_io(data, datalen, addr);
 }
 
 static void mlxcpld_i2c_write_comm(struct mlxcpld_i2c_priv *priv, u8 offs,
-- 
2.34.1

