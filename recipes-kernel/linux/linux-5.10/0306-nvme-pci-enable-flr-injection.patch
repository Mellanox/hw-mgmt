+#ifdef CONFIG_FAULT_INJECTION_DEBUG_FS
+static const char * const nvme_reset_action_names[] = {
+	[NVME_INJECT_RESET_NONE]	= "ctrl",
+	[NVME_INJECT_RESET_FLR]		= "flr",
+	[NVME_INJECT_RESET_CTRL_FLR]	= "ctrl_flr",
+};
+
+static ssize_t reset_action_show(struct device *dev,
+				 struct device_attribute *attr, char *buf)
+{
+	return sysfs_emit(buf, "%s %s %s\n",
+			  nvme_reset_action_names[0],
+			  nvme_reset_action_names[1],
+			  nvme_reset_action_names[2]);
+}
+
+static ssize_t reset_action_store(struct device *dev,
+				  struct device_attribute *attr,
+				  const char *buf, size_t count)
+{
+	struct nvme_ctrl *ctrl = dev_get_drvdata(dev);
+	struct nvme_dev *ndev = to_nvme_dev(ctrl);
+	int i, ret;
+
+	for (i = 0; i < ARRAY_SIZE(nvme_reset_action_names); i++) {
+		if (sysfs_streq(buf, nvme_reset_action_names[i]))
+			break;
+	}
+	if (i >= ARRAY_SIZE(nvme_reset_action_names))
+		return -EINVAL;
+
+	ndev->inject_reset_action = i;
+	ret = nvme_reset_ctrl(ctrl);
+	if (!ret) {
+		flush_work(&ctrl->reset_work);
+		if (ctrl->state != NVME_CTRL_LIVE)
+			ret = -ENETRESET;
+	}
+	if (ret < 0)
+		return ret;
+
+	return count;
+}
+static DEVICE_ATTR_RW(reset_action);
