From 0671fc470300e146a0658f159210e806a6cb4b50 Mon Sep 17 00:00:00 2001
From: Ciju Rajan K <crajank@nvidia.com>
Date: Fri, 29 May 2026 08:35:01 +0300
Subject: platform: mellanox: Add support for SN6200_LD

Host platform driver for SN6200 sp6 switch.

Signed-off-by: Ciju Rajan K <crajank@nvidia.com>
---
 drivers/platform/mellanox/Kconfig            |  10 +
 drivers/platform/mellanox/Makefile           |   1 +
 drivers/platform/mellanox/nvsw-host-sn6200.c | 686 +++++++++++++++++++
 drivers/platform/mellanox/nvsw.h             |   1 +
 4 files changed, 698 insertions(+)
 create mode 100644 drivers/platform/mellanox/nvsw-host-sn6200.c

diff --git a/drivers/platform/mellanox/Kconfig b/drivers/platform/mellanox/Kconfig
index f7b5a428472a..3146eb9a89bd 100644
--- a/drivers/platform/mellanox/Kconfig
+++ b/drivers/platform/mellanox/Kconfig
@@ -153,6 +153,16 @@ config NVSW_HOST_SPC6
 	 This driver can also be built as a module. If so the module
 	 will be called nvsw-host-spc6.
 
+config NVSW_HOST_SN6200
+	tristate "Nvidia SN6200_LD host CPLD/FPGA Hardware Control and Monitoring"
+	depends on HWMON
+	select REGMAP_I2C
+	help
+	Say Y here to include support for the FPGA/CPLD logic by host CPU
+	equipped on the Nvidia SN6200_LD ethernet switch (SKU HI195, VMOD0025).
+	 This driver can also be built as a module. If so the module
+	 will be called nvsw-host-sn6200.
+
 config NVSW_SN2201
 	tristate "Nvidia SN2201 platform driver support"
 	depends on HWMON && I2C
diff --git a/drivers/platform/mellanox/Makefile b/drivers/platform/mellanox/Makefile
index e26f268e6450..10e34e5dc8ec 100644
--- a/drivers/platform/mellanox/Makefile
+++ b/drivers/platform/mellanox/Makefile
@@ -16,4 +16,5 @@ obj-$(CONFIG_NVSW_BMC_HID162) += nvsw-bmc-hid162.o nvsw-core.o
 obj-$(CONFIG_NVSW_HOST_L1) += nvsw-host-l1.o nvsw-core.o
 obj-$(CONFIG_NVSW_HOST_SPC5) += nvsw-host-spc5.o nvsw-core.o
 obj-$(CONFIG_NVSW_HOST_SPC6) += nvsw-host-spc6.o nvsw-core.o
+obj-$(CONFIG_NVSW_HOST_SN6200) += nvsw-host-sn6200.o nvsw-core.o
 obj-$(CONFIG_NVSW_SN2201) += nvsw-sn2201.o
