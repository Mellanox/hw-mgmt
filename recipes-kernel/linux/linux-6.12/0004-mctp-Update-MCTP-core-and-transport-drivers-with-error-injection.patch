+static __poll_t mctp_poll(struct file *file, struct socket *sock,
+			  poll_table *wait)
+{
+	struct sock *sk = sock->sk;
+	__poll_t mask;
+
+	/* Use standard datagram_poll for normal data */
+	mask = datagram_poll(file, sock, wait);
+
