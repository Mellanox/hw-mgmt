"/var/log/hw-mgmt.trace.log" {
    size 2M
    rotate 3
    copytruncate
    compress
    delaycompress
    dateext
    dateformat -%Y%m%d%H%M%S
    missingok
    notifempty
}

# Active log + rotate 2 => three rotated files (see logrotate.conf.5); compressed after delaycompress.
"/var/log/hw-mgmt-i2c-trace.log" {
    size 2M
    rotate 2
    copytruncate
    compress
    delaycompress
    missingok
    notifempty
}
