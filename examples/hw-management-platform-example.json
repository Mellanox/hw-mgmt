{
    "_comment": "Example platform config for /etc/<HID>/hw-management-platform.json. Remove _comment before deploy.",
    "system": {
        "_comment_bmc": "yes | no",
        "bmc": "yes",
        "_comment_cooling": "liquid | air | hybrid",
        "cooling": "air",
        "_comment_power_supply": "AC | DC",
        "power_supply": "AC",
        "_comment_power_source": "busbar | replaceable_unit",
        "power_source": "replaceable_unit",
