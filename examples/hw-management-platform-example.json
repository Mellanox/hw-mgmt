        "erot_count": 0,
        "vrot_count": 0,
        "mcu_count": 0,
        "cartridge_count": 0,
        "asic_control": 1,
        "health_events_count": 0,
        "pwr_events_count": 0,
        "dpu_count": 0,
        "psu_count": 2,
        "minimal_unsupported": 0,
        "dummy_psus_supported": 0,
        "leakage_count": 0,
