                "addr": "0x21",
                "bus": 26,
                "name": "voltmon1"
            }
        ],
        "cpu_board_offset": 18,
        "named_busses_table": "p4300_named_busses",
        "named_busses": [
            {
                "name": "ts",
                "bus": 7
            },
            {
                "name": "vpd",
                "bus": 8
            }
        ],
